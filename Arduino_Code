#include <SoftwareSerial.h>
#include <RBDdimmer.h>

#define bulb1 6
#define bulb2 7

#define outputPin 3
#define zerocross 2

dimmerLamp fan(outputPin);

SoftwareSerial BT(10,11);

char data;
int speedValue = 0;

void setup()
{
  Serial.begin(9600);
  BT.begin(9600);

  pinMode(bulb1, OUTPUT);
  pinMode(bulb2, OUTPUT);

  fan.begin(NORMAL_MODE, ON);
  fan.setPower(0);
}

void loop()
{

  if (BT.available())
  {
    data = BT.read();

    if (data == 'A')
    {
      digitalWrite(bulb1, HIGH);
    }

    if (data == 'a')
    {
      digitalWrite(bulb1, LOW);
    }

    if (data == 'B')
    {
      digitalWrite(bulb2, HIGH);
    }

    if (data == 'b')
    {
      digitalWrite(bulb2, LOW);
    }

    if (isDigit(data))
    {
      speedValue = BT.parseInt();

      if(speedValue >= 0 && speedValue <= 100)
      {
        fan.setPower(speedValue);
      }
    }
  }
}
